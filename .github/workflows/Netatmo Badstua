name: Netatmo Badstua

on:
  workflow_dispatch:
  schedule:
    - cron: "*/10 * * * *"   # elke 10 minuten

jobs:
  netatmo:
    runs-on: ubuntu-latest

    steps:
      - name: Checkout repository
        uses: actions/checkout@v4

      - name: Haal Badstua temperatuur + luchtvochtigheid op
        env:
          CLIENT_ID: ${{ secrets.NETATMO_CLIENT_ID }}
          CLIENT_SECRET: ${{ secrets.NETATMO_CLIENT_SECRET }}
          REFRESH_TOKEN: ${{ secrets.NETATMO_REFRESH_TOKEN }}
        run: |
          TOKEN_RESPONSE=$(curl -s https://api.netatmo.com/oauth2/token \
            -d grant_type=refresh_token \
            -d client_id="$CLIENT_ID" \
            -d client_secret="$CLIENT_SECRET" \
            -d refresh_token="$REFRESH_TOKEN")

          ACCESS_TOKEN=$(echo "$TOKEN_RESPONSE" | jq -r '.access_token')
          if [ -z "$ACCESS_TOKEN" ]; then exit 1; fi

          STATION_RESPONSE=$(curl -s https://api.netatmo.com/api/getstationsdata \
            -H "Authorization: Bearer $ACCESS_TOKEN")

          TEMPERATURE=$(echo "$STATION_RESPONSE" | jq -r '
            .body.devices[].modules[]
            | select(.module_name == "Badstua")
            | .dashboard_data.Temperature
          ')

          HUMIDITY=$(echo "$STATION_RESPONSE" | jq -r '
            .body.devices[].modules[]
            | select(.module_name == "Badstua")
            | .dashboard_data.Humidity
          ')

          if [ -z "$TEMPERATURE" ] || [ -z "$HUMIDITY" ]; then exit 1; fi

          echo "{ \"temperature\": $TEMPERATURE, \"humidity\": $HUMIDITY }" > badstua.json

      - name: Commit en push data
        run: |
          git config user.name "github-actions"
          git config user.email "actions@github.com"
          git add badstua.json
          git pull --rebase origin main
          git commit -m "Update Badstua temperatuur en luchtvochtigheid" || echo "Geen wijziging"
          git push
``
